NODE_ENV=development
groq_api_key=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

# ─── Shopify OAuth (required for multi-merchant / global deployment) ───────────
# Get these from your Shopify Partner Dashboard → App → API credentials
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# The public URL of YOUR backend server (no trailing slash)
# Must match the "Allowed redirection URL(s)" you set in your Shopify Partner app
SHOPIFY_APP_URL=https://your-backend-domain.com

# Where to redirect merchants after a successful install
FRONTEND_URL=https://your-frontend-domain.com

# Scopes your app requests — edit only if you need extra permissions
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_inventory,write_inventory,read_fulfillments,write_fulfillments,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders

# ─── Legacy / single-store fallback (optional, for local dev only) ─────────────
# Remove these once every merchant connects via OAuth
